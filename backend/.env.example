# Orvannis backend — required environment variables
# Copy this file to .env for local testing, or enter these directly into
# your Railway / Render dashboard's environment variables section.
# The server will fail to start if any of these are missing.

# Resend API key — get from resend.com after verifying your domain
RESEND_API_KEY=

# Sending identity — leave as-is (must match your verified Resend domain)
SENDER_EMAIL=brian@orvannis.com

# Who gets the internal notification when a form is submitted (comma-separated, no spaces)
NOTIFY_EMAILS=brian@orvannis.com,boc_173@yahoo.com

# SQLite database path — set to the persistent disk path on Railway/Render
DB_PATH=/data/orvannis.db

# Protects GET /admin/report. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=
